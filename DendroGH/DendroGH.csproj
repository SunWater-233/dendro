<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net48;net7.0-windows</TargetFrameworks>
    <OutputType>Library</OutputType>
    <RootNamespace>DendroGH</RootNamespace>
    <AssemblyName>DendroGH</AssemblyName>
    <ProjectGuid>{A45EBB63-85ED-4B96-BC3A-21221C1DC605}</ProjectGuid>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <FallbackCulture>en-US</FallbackCulture>
    <PlatformTarget>x64</PlatformTarget>
    <Prefer32Bit>false</Prefer32Bit>
    <RhinoPackageVersion>8.32.26160.13001</RhinoPackageVersion>
    <RepositoryRoot>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\'))</RepositoryRoot>
    <OutputPath>$(RepositoryRoot)x64\$(Configuration)\</OutputPath>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|AnyCPU' Or '$(Configuration)|$(Platform)' == 'Debug|x64'">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <StartProgram>C:\Program Files\Rhino 8\System\Rhino.exe</StartProgram>
    <StartArguments>/netcore-8</StartArguments>
    <StartAction>Program</StartAction>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|AnyCPU' Or '$(Configuration)|$(Platform)' == 'Release|x64'">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <DefineConstants>TRACE</DefineConstants>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Grasshopper" Version="$(RhinoPackageVersion)" />
    <PackageReference Include="RhinoCommon" Version="$(RhinoPackageVersion)" />
    <PackageReference Include="System.Resources.Extensions" Version="7.0.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="app.config" />
  </ItemGroup>

  <Target Name="CreateGrasshopperAssembly" AfterTargets="Build" Condition="'$(TargetFramework)' != ''">
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="$(TargetDir)$(AssemblyName).gha" />
    <Delete Files="$(TargetPath)" />
  </Target>

  <Target Name="CopyNativeDendroApi" AfterTargets="Build" Condition="'$(TargetFramework)' != ''">
    <PropertyGroup>
      <DendroApiSource>$(RepositoryRoot)x64\$(Configuration)\DendroAPI.dll</DendroApiSource>
      <DendroApiSource Condition="!Exists('$(DendroApiSource)')">$(RepositoryRoot)DendroAPI\x64\$(Configuration)\DendroAPI.dll</DendroApiSource>
    </PropertyGroup>
    <Copy SourceFiles="$(DendroApiSource)" DestinationFolder="$(TargetDir)" Condition="Exists('$(DendroApiSource)')" />
  </Target>

</Project>
